                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='12000' id='17' type-v2='text' w='98666' x='667' y='87000'>
                  <formatted-text>
                    <run bold='true' fontcolor='#222222' fontname='Arial' fontsize='10'>Created by Zachary Niccoli</run>
                    <run>Æ&#10;</run>
                    <run bold='true' fontcolor='#222222' fontname='Arial' fontsize='10'>Data Modeling in Python, SQL and Tableau</run>
                    <run>Æ&#10;</run>
