      <aliases enabled='yes' />
      <column caption='District Rank' datatype='string' name='[Calculation_1243317005529088]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [district_name] = [Parameters].[Parameter 1] THEN &quot;Selected&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='SES Band' datatype='string' name='[Calculation_1243317023821829]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ses_index] &lt; -1 THEN &quot;Low SES&quot;&#13;&#10;ELSEIF [ses_index] &lt; 1 THEN &quot;Mid SES&quot;&#13;&#10;ELSE &quot;High SES&quot;&#13;&#10;END' />
      </column>
      <column caption='Peer District' datatype='boolean' name='[Calculation_1243317024075782]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1243317023821829] = [Calculation_1243317025538055]' />
      </column>
      <column caption='Selected SES Band' datatype='string' name='[Calculation_1243317025538055]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    MAX(&#13;&#10;        IF [district_name] = [Parameters].[Parameter 1]&#13;&#10;        THEN [Calculation_1243317023821829]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Gap Rank' datatype='integer' name='[Calculation_1243317026709513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(AVG([performance_gap]))'>
          <table-calc ordering-field='[federated.1erh0rc0z8w2bm1840hi00e41d38].[district_name]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Highlight District' datatype='string' name='[Calculation_1243317027704843]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF MIN([district_name]) = [Parameters].[Parameter 1]&#13;&#10;THEN &quot;Selected District&quot;&#13;&#10;ELSE &quot;Other Districts&quot;&#13;&#10;END' />
      </column>
      <column caption='Selected District Rank' datatype='integer' name='[Calculation_1243317028077581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(&#13;&#10;    IF MIN([district_name]) = [Parameters].[Parameter 1]&#13;&#10;    THEN [Calculation_1243317026709513]&#13;&#10;    END&#13;&#10;)'>
          <table-calc ordering-field='[federated.1erh0rc0z8w2bm1840hi00e41d38].[district_name]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='Rank Filter' datatype='boolean' name='[Calculation_1243317028208654]' role='measure' type='nominal'>
        <calculation class='tableau' formula='ABS([Calculation_1243317026709513] - [Calculation_1243317028077581]) &lt;= 10'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Peer Average' datatype='real' name='[Calculation_1243317038243858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([performance_gap])' />
      </column>
      <column caption='Top/Bottom 20 Filter' datatype='string' name='[Calculation_1454697851744258]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF RANK(AVG([performance_gap])) &lt;= 20&#13;&#10;OR RANK(-AVG([performance_gap])) &lt;= 20&#13;&#10;THEN &quot;Keep&quot;&#13;&#10;ELSE &quot;Exclude&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='District Filter' datatype='boolean' name='[Calculation_1454697854681091]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[district_name] = [Parameters].[Parameter 1]' />
      </column>
